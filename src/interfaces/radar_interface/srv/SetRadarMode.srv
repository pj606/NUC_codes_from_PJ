uint8 MODE_IDLE=0
uint8 MODE_SCAN=1
uint8 MODE_TRACK=2
uint8 MODE_DEBUG=3
# mode: use MODE_* constants
uint8 mode
# enable flags behavior:
# - IDLE: ignored
# - SCAN: enable_detection applied, enable_tracking ignored
# - TRACK: enable_tracking applied, enable_detection optional
# - DEBUG: both applied
# mode transition: entering IDLE or SCAN should reset tracking state; entering TRACK preserves last targets if available
bool enable_detection
bool enable_tracking
string source
---
bool accepted
string message
