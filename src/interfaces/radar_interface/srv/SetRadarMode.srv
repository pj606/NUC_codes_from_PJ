# mode: 0=IDLE, 1=SCAN, 2=TRACK, 3=DEBUG
uint8 mode
# enable flags behavior:
# - IDLE: ignored
# - SCAN: enable_detection applied, enable_tracking ignored
# - TRACK: enable_tracking applied, enable_detection optional
# - DEBUG: both applied
bool enable_detection
bool enable_tracking
string source
---
bool accepted
string message
